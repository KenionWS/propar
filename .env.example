# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — https://resend.com (API Keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Cotizia <onboarding@resend.dev>

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AFIP / ARCA — facturación electrónica (a futuro; ver src/lib/afip.ts)
# Mientras estén vacías, el botón "Facturar" avisa que no está configurado.
AFIP_CUIT=
AFIP_PUNTO_VENTA=
AFIP_CERT=
AFIP_KEY=
AFIP_ENV=homologacion
# Solo en dev detrás de un proxy que intercepta TLS: 1 = no validar el
# certificado del servidor de AFIP. NUNCA usar en producción.
AFIP_INSECURE_TLS=
